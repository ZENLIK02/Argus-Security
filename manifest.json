{
  "manifest_version": 3,
  "name": "Project Argus",
  "version": "5.3.0",
  "description": "A local browser security engine that correlates phishing, data-leak, scam, and suspicious download evidence.",
  "permissions": [
    "storage",
    "tabs",
    "activeTab",
    "downloads",
    "webRequest",
    "offscreen"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "service_worker.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Project Argus"
  },
  "options_page": "options.html",
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "engine/shared_lists.js",
        "content.js"
      ],
      "css": [
        "style.css"
      ],
      "run_at": "document_idle"
    }
  ]
}
